# ── Secrets ────────────────────────────────────────────────────────────────────
.env

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
*.egg-info/

# ── Data — auto-generated, large, or personal ──────────────────────────────────
data/vector_db/
data/intel/latest_feed.json
data/intel/seen_hashes.json
data/intel/alerts_log.json
data/intel/ideas_log.json
data/intel/market_history.db
data/intel/.research.lock
data/logs/
data/exports/
data/processed/
