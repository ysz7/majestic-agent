data/backups/last_backup.json
data/tokens.json
data/config.json

# Keep RSS feed list (user config, not sensitive)
!data/intel/rss_feeds.json

# ── Local / user-custom tools (not tracked) ───────────────────────────────────
majestic/tools/local/*.py
!majestic/tools/local/.gitkeep

# ── IDE / tooling ──────────────────────────────────────────────────────────────
.claude/
.idea/
.vscode/
*.swp

# ── Private notes ──────────────────────────────────────────────────────────────
PRIVATE-README.md
CLAUDE.md
PLAN.md
PLAN.MD

# ── OS ─────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
