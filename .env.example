# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama              # ollama | anthropic
OLLAMA_MODEL=gemma3
OLLAMA_NUM_CTX=32768
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=        # your Telegram user ID (comma-separated for multiple)
MORNING_BRIEFING_HOUR=8          # send daily briefing at this hour (24h), 0 = off

# ── Research ───────────────────────────────────────────────────────────────────
TAVILY_API_KEY=                  # optional, better search quality — free at app.tavily.com
AUTO_RESEARCH_INTERVAL=240       # auto-collect every N minutes, 0 = off
REDDIT_SUBS=                     # comma-separated, empty = defaults
MASTODON_INSTANCE=mastodon.social
DEVTO_API_KEY=                   # optional, get at dev.to/settings/extensions
GOOGLE_TRENDS_GEO=US             # 2-letter country code

# ── Market data ────────────────────────────────────────────────────────────────
ALPHAVANTAGE_KEY=                # free at alphavantage.co
FINNHUB_KEY=                     # free at finnhub.io
CRYPTO_COINS=bitcoin,ethereum,solana
STOCK_SYMBOLS=AAPL,NVDA,MSFT
FOREX_PAIRS=EUR,GBP,JPY
