# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCDEFghijklmnop...
# Comma-separated Telegram user IDs allowed to use the bot (empty = allow all)
TELEGRAM_ALLOWED_IDS=123456789

# ── Discord ───────────────────────────────────────────────────────────────────
# DISCORD_BOT_TOKEN=...  # from https://discord.com/developers/applications

# ── Research APIs (all optional) ─────────────────────────────────────────────
# TAVILY_API_KEY=tvly-...         # better web search (free at app.tavily.com)
# NEWSAPI_KEY=...                  # NewsAPI.org
# ALPHAVANTAGE_KEY=...             # stock data (free at alphavantage.co)
# FINNHUB_KEY=...                  # stock/crypto data (free at finnhub.io)

# ── Runtime (override defaults) ───────────────────────────────────────────────
# MAJESTIC_HOME=~/.majestic-agent  # all data lives here (set to /data in Docker)
